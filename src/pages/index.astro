<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Aleix Baldich | portfolio</title>
		<style>
      
      :root {
        --bg-color: #121212;
        --text-color: #a3a3a3;
        --text-heading: #f3f4f6;
        --accent: #ec4899; 
        --border-color: #262626;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        background-color: var(--bg-color);
        color: var(--text-color);
        max-width: 680px; 
        margin: 0 auto;
        padding: 4rem 1.5rem;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      
      header {
        margin-bottom: 3rem;
      }

      h1 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-heading);
        margin-bottom: 0.5rem;
        letter-spacing: -0.025em;
      }

      h2 {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-heading);
        margin-top: 3rem;
        margin-bottom: 1.5rem;
        letter-spacing: -0.025em;
      }

      p {
        margin-bottom: 1rem;
        font-size: 0.95rem;
      }

      strong {
        color: var(--text-heading);
        font-weight: 500;
      }

      /* Enlaces de contacto */
      .links-contact {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
        font-size: 0.9rem;
      }

      
      .projects-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .project-item {
        text-decoration: none;
        display: block;
        padding: 1rem;
        margin: 0 -1rem; 
        border-radius: 8px;
        transition: background-color 0.2s ease, border-color 0.2s ease;
        border: 1px solid transparent;
      }

      .project-item:hover {
        background-color: #1a1a1a;
        border-color: var(--border-color);
      }

      .project-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 0.25rem;
      }

      .project-title {
        font-size: 1rem;
        font-weight: 500;
        color: var(--text-heading);
        transition: color 0.2s ease;
      }

      .project-item:hover .project-title {
        color: var(--accent);
      }

      .project-tech {
        font-size: 0.8rem;
        color: #64748b;
        font-family: monospace;
      }

      .project-desc {
        font-size: 0.9rem;
        color: #737373;
        margin: 0;
      }

      
      a {
        color: var(--text-heading);
        text-decoration: underline;
        text-underline-offset: 4px;
        text-decoration-color: #404040;
        transition: text-decoration-color 0.2s ease, color 0.2s ease;
      }

      a:hover {
        color: var(--accent);
        text-decoration-color: var(--accent);
      }
    </style>
	</head>
	<body>
		<header>
			<h1>Aleix Baldich</h1>
			<p>Estudiante de Ingeniería Informática enfocado en <strong>Ciberseguridad</strong> y Desarrollo de Software.</p>
			
			<div class="links-contact">
				<a href="https://github.com/aleixbaldich" target="_blank">GitHub</a>
				<a href="https://www.linkedin.com/in/aleix-baldich-19b78a351/" target="_blank">LinkedIn</a>
			</div>
		</header>

		
	</body>
</html>
